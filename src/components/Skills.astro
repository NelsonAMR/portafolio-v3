---
import { SkillCard } from "./";
import { skills } from "../utils/skills";
import { getI18n, type Locale } from "../i18n/ui";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getI18n(locale);
---

<section id="skills" class="skills">
  <h2>{t.skills.title}</h2>

  <div class="skills-cont">
    {
      skills.map((skill) => (
        <SkillCard
          img={skill.img}
          name={skill.name}
          level={skill.level}
          levelLabels={t.skills.levels}
        />
      ))
    }
  </div>
</section>

<style lang="scss">
  @use "../styles/mixins" as m;

  .skills {
    margin-bottom: 10rem;

    h2 {
      margin-bottom: 5rem;

      @include m.tablet {
        text-align: center;
      }
    }
  }

  .skills-cont {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    // animation-name: come;
    // animation-duration: 2s;

    @include m.tablet {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: space-around;
    }
  }

  @keyframes come {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }
</style>
