---
import { getI18n, type Locale } from "../i18n/ui";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getI18n(locale);
---

<section class="home container" id="home">
  <h1>{t.home.greeting} <span>Nelson</span></h1>
  <h2>{t.home.role}</h2>
  <p>{t.home.subtitle}</p>
  <a
    href="/NelsonMacias-WebDeveloper.pdf"
    target="_blank"
    class="button">{t.home.resumeCta}</a
  >
</section>

<style lang="scss">
  @use "../styles/variables.scss" as v;
  @use "../styles/mixins.scss" as m;

  .home {
    height: calc(100vh - 8rem);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: 1rem;
    padding-bottom: 5rem;

    p {
      margin-top: 1rem;
      font-size: 2rem;
    }

    h1 {
      font-size: 4rem;

      @include m.tablet {
        font-size: 5.5rem;
      }

      span {
        color: v.$secondary;
      }
    }

    h2 {
      @include m.tablet {
        font-size: 4rem;
      }
    }

    a {
      margin-top: 1rem;
      font-size: 2rem;
      width: 100%;
      max-width: 40rem;
    }
  }
</style>
