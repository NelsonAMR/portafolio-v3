---
import { projects } from "../utils/projects";
import Project from "./Project.astro";
import { getI18n, type Locale } from "../i18n/ui";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getI18n(locale);
---

<section id="projects" class="projects">
  <h2>{t.projects.title}</h2>

  <div class="projects-cont">
    {
      projects.map((project) => (
        <Project project={project} locale={locale} demoLabel={t.projects.demo} repoLabel={t.projects.repo} />
      ))
    }
  </div>
</section>

<style lang="scss">
  @use "../styles/mixins.scss" as m;

  .projects {
    margin-bottom: 10rem;

    h2 {
      margin-bottom: 5rem;

      @include m.tablet {
        text-align: center;
      }
    }
  }

  .projects-cont {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem 1rem;

    @include m.tablet {
      flex-direction: row;
      flex-wrap: wrap;
      justify-content: space-around;
    }
  }
</style>
