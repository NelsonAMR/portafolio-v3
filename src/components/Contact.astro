---
import { getI18n, type Locale } from "../i18n/ui";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getI18n(locale);
---

<section class="form-cont" id="contact">
  <h2>{t.contact.title}</h2>

  <form
    class="form"
    id="contact-form"
    data-success-title={t.contact.successTitle}
    data-error-title={t.contact.errorTitle}
    data-error-text={t.contact.errorText}
  >
    <div class="form-camp">
      <label for="camp-name">{t.contact.name}</label>
      <input type="text" required id="camp-name" name="name" />
    </div>

    <div class="form-camp">
      <label for="camp-phone">{t.contact.phone}</label>
      <input type="tel" id="camp-phone" name="phone" />
    </div>

    <div class="form-camp">
      <label for="camp-email">{t.contact.email}</label>
      <input type="email" required id="camp-email" name="email" />
    </div>

    <div class="form-camp">
      <label for="camp-subject">{t.contact.subject}</label>
      <input type="text" required id="camp-subject" name="subject" />
    </div>

    <div class="form-camp">
      <label for="camp-message">{t.contact.message}</label>
      <textarea id="camp-message" required name="message"></textarea>
    </div>

    <button class="button">{t.contact.send}</button>
  </form>
</section>

<style lang="scss">
  @use "../styles/variables.scss" as v;
  @use "../styles/mixins.scss" as m;

  .form-cont {
    margin-bottom: 10rem;

    h2 {
      margin-bottom: 5rem;

      @include m.tablet {
        text-align: center;
      }
    }
  }

  .form {
    margin: 0 auto;
    width: 100%;
    max-width: 50rem;

    @include m.tablet {
      display: flex;
      flex-wrap: wrap;
      gap: 1.6rem;
    }

    .form-camp {
      display: flex;
      width: 100%;
      flex-direction: column;
      margin-bottom: 2.5rem;

      @include m.tablet {
        margin-bottom: 0.5rem;

        &:nth-child(-n + 2) {
          width: calc(50% - 1rem);
        }
      }

      label {
        margin-bottom: 0.8rem;
        font-size: 1.8rem;
      }

      input,
      textarea {
        height: 4rem;
        font-size: 2rem;
        color: v.$primary;
        background-color: v.$white;
        border-radius: 0.5rem;
        border: 0.1rem solid v.$gray-l;
        padding-left: 1rem;
        outline: none;
        font-family: inherit;

        &:focus {
          border: none;
          outline: 0.2rem solid lighten(v.$purple, 15%);
        }
      }

      textarea {
        padding: 1rem;
        height: 15rem;
        resize: none;
      }
    }

    button {
      margin-top: 2.5rem;
      width: 100%;
      font-size: 2rem;

      @include m.tablet {
        display: block;
        margin-left: auto;
        width: 20rem;
      }
    }
  }
</style>

<script>
  import Swal from "sweetalert2";
  import emailjs from "@emailjs/browser";

  const emailKey = import.meta.env.PUBLIC_EMAIL_KEY;
  const serviceId = import.meta.env.PUBLIC_EMAIL_SERVICE;
  const templateId = import.meta.env.PUBLIC_EMAIL_TEMPLATE;

  const form = document.getElementById("contact-form") as HTMLFormElement;
  const successTitle = form?.dataset.successTitle ?? "Email sent!";
  const errorTitle = form?.dataset.errorTitle ?? "Oops...";
  const errorText = form?.dataset.errorText ?? "The email could not be sent";

  form?.addEventListener("submit", sendEmail);

  async function sendEmail(event: SubmitEvent) {
    event.preventDefault();

    try {
      await emailjs.sendForm(serviceId, templateId, form);
      
      form.reset();
      Swal.fire({
        icon: "success",
        title: successTitle,
        timer: 1500,
        showConfirmButton: false,
      });
    } catch (error) {
      console.log(error);

      Swal.fire({
        icon: "error",
        title: errorTitle,
        text: errorText,
        timer: 2000,
        showConfirmButton: false,
      });
    }
  }

  emailjs.init(emailKey);
</script>
